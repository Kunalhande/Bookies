<div class="book-form-card">

  <%= form_with model: @book do |f| %>

    <div class="form-group">
      <%= f.label :book_title, "Book Title", class: "form-label" %>
      <%= f.text_field :book_title, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :authors, class: "form-label" %>

      <div class="dropdown">
        <button type="button"
                class="author-btn dropdown-toggle"
                data-bs-toggle="dropdown">
          Select Authors
        </button>

        <ul class="dropdown-menu p-3">
          <% @authors.each do |author| %>
            <li style="list-style:none;">
              <label>
                <%= check_box_tag "book[author_ids][]",
                                  author.id,
                                  @book.author_ids.include?(author.id) %>

                <%= author.first_name %>
              </label>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <%= f.submit (@book.new_record? ? "Create Book" : "Update Book"),
                 class: "submit-btn" %>

  <% end %>

</div>