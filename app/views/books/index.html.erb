<h1>Books</h1>

<%= link_to "Add Book", new_book_path %>

<br><br>

<table border="1" cellpadding="10" cellspacing="0">
  <tr>
    <th>Book Title</th>
    <th>Authors</th>
    <th>Actions</th>
  </tr>

  <% @books.each do |book| %>
    <tr>
      <td><%= book.book_title %></td>

      <td>
        <%= book.authors.map(&:first_name).join(", ") %>
      </td>

      <td>
        <%= link_to "Edit", edit_book_path(book) %>

        <%= button_to "Delete",
              book,
              method: :delete,
              form: { style: "display:inline;" } %>
      </td>
    </tr>
  <% end %>
</table>