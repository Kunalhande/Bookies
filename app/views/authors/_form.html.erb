<div class="book-form-card">

  <%= form_with model: @author do |f| %>

    <div class="form-group">
      <%= f.label :first_name, class: "form-label" %>
      <%= f.text_field :first_name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :last_name, class: "form-label" %>
      <%= f.text_field :last_name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :date_of_birth, class: "form-label" %>
      <%= f.date_field :date_of_birth, class: "form-input" %>
    </div>

    <%= f.submit (@author.new_record? ? "Create Author" : "Update Author"),
                 class: "submit-btn" %>

  <% end %>

</div>